# ─────────────────────────────────────────────────────────────────────────────
# Archon Memory — CockroachDB × AWS Bedrock
# Copy to `.env` and fill in. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# --- CockroachDB (the agent memory layer) -----------------------------------
# Local single-node (docker compose up) — insecure, dev only:
#   postgresql://root@localhost:26257/archon_memory?sslmode=disable
# CockroachDB Cloud Serverless (production) — copy from `ccloud cluster sql`:
#   postgresql://<user>:<pass>@<host>:26257/archon_memory?sslmode=verify-full
DATABASE_URL=postgresql://root@localhost:26257/archon_memory?sslmode=disable

# CockroachDB Cloud (ccloud CLI) — used by scripts/provision-cluster.sh
CCLOUD_API_KEY=
COCKROACH_CLUSTER_NAME=archon-memory

# --- AWS Bedrock (embeddings + narration) -----------------------------------
# Reuses the H0 Archon AWS account. Bedrock must be enabled in this region.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
BEDROCK_REGION=us-west-2

# Titan Text Embeddings V2 → 1024-dim vectors (must match schema VECTOR(1024))
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
EMBED_DIM=1024

# Claude Sonnet on Bedrock — document vision-extraction + agent narration
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# --- App ---------------------------------------------------------------------
PORT=3000
