# Archon Memory — local/operator example only.
# Copy to .env and fill values. Never commit .env or credentials.

# Local CockroachDB for development:
DATABASE_URL=postgresql://root@localhost:26257/archon_memory?sslmode=disable

# Production Lambda uses only the deterministic secret name; its JSON contains DATABASE_URL.
DATABASE_SECRET_ID=archon-memory/production/database
COCKROACH_REGION=eu-west-1

# Fixed judge scope. CloudFormation and CockroachDB RLS accept only these values.
PUBLIC_DEMO_TENANT_ID=public-demo
PUBLIC_DEMO_COMPANY=Helios SA

# CockroachDB Cloud Managed MCP read-only audit.
CCLOUD_API_KEY=
COCKROACH_CLUSTER_ID=
COCKROACH_DATABASE=archon

# ccloud cluster operations authenticate interactively with:
#   ccloud auth login
# CCLOUD_API_KEY is for Managed MCP, not ccloud CLI authentication.
COCKROACH_CLUSTER_NAME=archon-cockroachdb-cluster

# AWS SDK credentials are supplied by the operator locally and OIDC in CI/CD.
AWS_REGION=eu-west-1
BEDROCK_REGION=eu-west-1
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_MODEL_ID=eu.anthropic.claude-sonnet-4-6
EMBED_DIM=1024

# Public API bounds.
RECALL_MAX_QUESTION_CHARS=500
RECALL_MIN_SCORE=0.15
PGPOOL_MAX=1
PGPOOL_MAX_LIFETIME_SECONDS=300

PORT=8787
